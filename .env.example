# Copy to `.env` and replace the endpoint with your form endpoint.
# Example: Formspree endpoint: https://formspree.io/f/your_form_id
# Then restart the dev server (`npm run dev`).

VITE_CONTACT_ENDPOINT="https://formspree.io/f/abcd1234"

# EmailJS (client-side)
# Create a service and template at https://dashboard.emailjs.com/
# Then add these values to your local `.env` and restart the dev server.
VITE_EMAILJS_SERVICE_ID="service_xxx"
VITE_EMAILJS_TEMPLATE_ID="template_xxx"
VITE_EMAILJS_PUBLIC_KEY="public_xxx"
